generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  INVESTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  transactions   Transaction[]
  balance        Balance?        @relation("UserBalance")
  investments    Investment[]
  expenses       Expense[]       @relation("UserExpenses")
  fixedIncome    FixedIncome?    @relation("UserFixedIncome")
  variableIncome VariableIncome? @relation("UserVariableIncome")
}

model Transaction {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  description String?
  amount      Float
  date        DateTime          @default(now())
  type        TransactionType
  status      TransactionStatus @default(PENDING)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])
}

model Balance {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  amount    Float     @default(0.0)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  userId String @unique @db.ObjectId
  user   User   @relation("UserBalance", fields: [userId], references: [id])
}

model FixedIncome {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  amount Float  @default(0.0)

  userId String @unique @db.ObjectId
  user   User   @relation("UserFixedIncome", fields: [userId], references: [id])
}

model VariableIncome {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float  @default(0.0)
  description String

  userId String @unique @db.ObjectId
  user   User   @relation("UserVariableIncome", fields: [userId], references: [id])
}

model Expense {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  category    String
  amount      Float     @default(0.0)
  description String
  dueDate     DateTime? @default(now())
  scheduledAt DateTime?

  userId String @db.ObjectId
  user   User   @relation("UserExpenses", fields: [userId], references: [id])
}

model Investment {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  purchaseDate DateTime
  updatedAt    DateTime? @updatedAt
  isRedeemed   Boolean   @default(false)

  userId           String                  @db.ObjectId
  investmentTypeId String                  @db.ObjectId
  user             User                    @relation(fields: [userId], references: [id])
  investmentType   InvestmentType          @relation(fields: [investmentTypeId], references: [id])
  applications     InvestmentApplication[]
}

model InvestmentType {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  name            String  @unique
  type            String
  percentageValue Float
  hasTax          Boolean @default(true)

  investments Investment[]
}

model InvestmentApplication {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  type   String
  amount Float
  date   DateTime

  investmentId String     @db.ObjectId
  investment   Investment @relation(fields: [investmentId], references: [id])
}
